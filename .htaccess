<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Kecualikan direktori atau file yang ada dari penulisan ulang URL
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Arahkan semua request lainnya ke index.php
    RewriteRule ^(.*)$ index.php/$1 [L]
</IfModule>

<IfModule !mod_rewrite.c>
    # Jika mod_rewrite tidak aktif, paksa error 404 agar server tidak mengekspos struktur folder
    ErrorDocument 404 /index.php
</IfModule>